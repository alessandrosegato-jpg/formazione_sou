Vagrant.configure("2") do |config|

          # ROCKY2 - WEB SERVER  
  config.vm.define "rocky1" do |vm|
    vm.vm.box = "generic/rocky9"
    vm.vm.hostname = "rocky1"
    vm.vm.network "private_network", ip: "192.168.3.2"
    vm.vm.network "forwarded_port", guest: 8443, host: 8443

    vm.vm.provision "shell", inline: <<-SHELL
      dnf update -y
      dnf install -y podman
      dnf install -y policycoreutils-python-utils
      firewall-cmd --add-port=8443/tcp --permanent
      firewall-cmd --reload
      semanage port -a -t http_port_t -p tcp 8443
     
      mkdir -p /var/www/html
      echo "Benvenuti nel mio server Apache! (in https :D )" > /var/www/html/index.html
     
      mkdir -p /etc/ssl/mycerts

      openssl req -new -x509 -days 365 -nodes -subj "/C=IT/ST=RM/L=Roma/O=Lab/CN=rocky1" -out /etc/ssl/mycerts/server.crt -keyout /etc/ssl/mycerts/server.key

      cat > /etc/ssl/mycerts/httpd-ssl.conf <<EOF
      LoadModule ssl_module modules/mod_ssl.so

      Listen 443

      <VirtualHost *:443>
      DocumentRoot "/usr/local/apache2/htdocs"

      SSLEngine on
      SSLCertificateFile "/usr/local/apache2/conf/server.crt"
      SSLCertificateKeyFile "/usr/local/apache2/conf/server.key"
      </VirtualHost>
EOF
      
      podman run -d --name apache \
      -p 8443:443 \
      -v /var/www/html:/usr/local/apache2/htdocs:Z \
      -v /etc/ssl/mycerts/server.crt:/usr/local/apache2/conf/server.crt:Z \
      -v /etc/ssl/mycerts/server.key:/usr/local/apache2/conf/server.key:Z \
      -v /etc/ssl/mycerts/httpd-ssl.conf:/usr/local/apache2/conf/extra/httpd-ssl.conf:Z \
      docker.io/library/httpd:2.4 \
      sh -c "echo 'Include conf/extra/httpd-ssl.conf' >> conf/httpd.conf && httpd-foreground"

      SHELL

    vm.vm.provider "virtualbox" do |vb|
      vb.memory = "1024"
      vb.cpus = 1
    end
  end

          # ROCKY3 - CLIENT
  config.vm.define "rocky2" do |vm|
    vm.vm.box = "generic/rocky9"
    vm.vm.hostname = "rocky2"
    vm.vm.network "private_network", ip: "192.168.3.3"

    vm.vm.provision "shell", inline: <<-SHELL
      dnf update -y
      dnf install -y curl
      
      SHELL

    vm.vm.provider "virtualbox" do |vb|
      vb.memory = "1024"
      vb.cpus = 1
    end
  end

end